<!-- RESERVATION -->
<section id="reservation" aria-labelledby="reservation-title">
  <div class="reservation-inner">
    <div class="reservation-info fade-in-left">
      <p class="section-label">Reserve Your Spot</p>
      <h2 class="section-title" id="reservation-title">Book a <em>Table</em></h2>
      <div class="section-divider"></div>
      <p>Mornings go fast. Secure your table ahead of time and walk in to the smell of fresh coffee and warm bread — no waiting, no missing out.</p>
      <div class="res-contact">
        <div class="res-contact-item">
          <div class="res-icon">📍</div>
          <span>12th Main, HAL 2nd Stage,<br>Indiranagar, Bangalore 560 008</span>
        </div>
        <div class="res-contact-item">
          <div class="res-icon">📞</div>
          <span>+91 80 4567 8900<br>+91 98450 12345</span>
        </div>
        <div class="res-contact-item">
          <div class="res-icon">🕐</div>
          <span>Mon – Fri: 7:30 AM – 3:00 PM<br>Sat – Sun: 7:00 AM – 4:00 PM</span>
        </div>
      </div>
    </div>
    <div class="res-form fade-in-right" id="resFormWrap">
      <div id="resFormContent">
        <div class="form-group">
          <label for="resName">Full Name</label>
          <input type="text" id="resName" placeholder="Priya Sharma" autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="resPhone">Phone Number</label>
          <input type="tel" id="resPhone" placeholder="+91 98XXX XXXXX" autocomplete="tel" />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="resDate">Date</label>
            <input type="date" id="resDate" />
          </div>
          <div class="form-group">
            <label for="resTime">Time</label>
            <input type="time" id="resTime" min="07:00" max="15:30" />
          </div>
        </div>
        <div class="form-group">
          <label for="resGuests">Number of Guests</label>
          <select id="resGuests">
            <option value="" disabled selected>Select guests</option>
            <option value="1">1 Guest</option>
            <option value="2">2 Guests</option>
            <option value="3">3 Guests</option>
            <option value="4">4 Guests</option>
            <option value="5">5 Guests</option>
            <option value="6">6 Guests</option>
            <option value="7-8">7–8 Guests</option>
            <option value="9+">9+ Guests (call us)</option>
          </select>
        </div>
        <div class="form-group">
          <label for="resNote">Special Requests (optional)</label>
          <input type="text" id="resNote" placeholder="Window seat, birthday, dietary needs…" />
        </div>
        <button class="btn-submit" id="resSubmit" type="button">Confirm Reservation →</button>
      </div>
      <div class="form-success" id="formSuccess">
        <div class="checkmark">✓</div>
        <h3>You're all set!</h3>
        <p>We've received your reservation and will send a confirmation to your phone shortly. See you soon!</p>
      </div>
    </div>
  </div>
</section>

