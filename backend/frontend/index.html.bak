      <div class="section-divider centered"></div>
      <p style="color:var(--text-light);max-width:480px;margin:0 auto;font-size:0.95rem;line-height:1.8;">Every item on our menu is made from scratch, seasoned with patience, and served with care. Here are some of our favourites.</p>
    </div>
    <div class="menu-tabs" role="tablist" aria-label="Menu categories">
      <button class="menu-tab active" data-cat="breakfast" role="tab" aria-selected="true">Breakfast</button>
      <button class="menu-tab" data-cat="beverages" role="tab" aria-selected="false">Beverages</button>
      <button class="menu-tab" data-cat="specials" role="tab" aria-selected="false">Chef's Specials</button>
    </div>
    <div class="menu-grid" id="menuGrid">

      <!-- BREAKFAST -->
      <article class="menu-card active" data-cat="breakfast" role="article">
