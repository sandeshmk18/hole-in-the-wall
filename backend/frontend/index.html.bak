        </div>
        <div class="menu-card-body">
          <h3 class="menu-card-name">Smashed Avocado Toast</h3>
          <p class="menu-card-desc">Sourdough, whipped ricotta, cherry tomatoes, microgreens, chilli flakes, poached egg.</p>
          <div class="menu-card-footer">
            <span class="menu-price">₹ 295</span>
            <span class="menu-tag tag-veg">Vegetarian</span>
          </div>
        </div>
      </article>

      <article class="menu-card active" data-cat="breakfast">
        <div style="overflow:hidden;height:180px">
